# ==========================================
# BACKEND - Servidor principal
# ==========================================
BACKEND_PORT=3000
BACKEND_HOST=localhost
NODE_ENV=development

# ==========================================
# Banco de Dados PostgreSQL
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=workflow_user
DB_PASSWORD=seu_senha_segura_aqui
DB_NAME=workflow_db
DB_SSL=false

# ==========================================
# JWT - Autenticação
# ==========================================
JWT_SECRET=sua_chave_secreta_muito_longa_e_segura_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=sua_chave_secreta_refresh_aqui
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# CORS - Segurança
# ==========================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# ==========================================
# Email - Notificações
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=noreply@workflow.com.br

# ==========================================
# S3 / Cloud Storage - Upload de arquivos
# ==========================================
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_S3_BUCKET=workflow-documents
S3_ENDPOINT=https://s3.sa-east-1.amazonaws.com

# ==========================================
# LOGGING - Rastreamento
# ==========================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ==========================================
# SEGURANÇA LGPD
# ==========================================
DATA_RETENTION_DAYS=2555
ENCRYPT_SENSITIVE_DATA=true
AUDIT_LOG_ENABLED=true

# ==========================================
# FRONTEND - Cliente web
# ==========================================
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000/api
