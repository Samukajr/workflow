# ==========================================
# VARIÁVEIS DE AMBIENTE - BACKEND
# ==========================================

# Porta do servidor
PORT=3000

# URLs permitidas para CORS (separadas por vírgula)
# Desenvolvimento:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Produção (Render + Vercel):
# ALLOWED_ORIGINS=https://workflow-frontend.vercel.app,https://workflow-backend.onrender.com

# Chave de criptografia (DEVE SER ALTERADA EM PRODUÇÃO)
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=chave-segura-32-caracteres-aqui-1

# Email para notificações (futuro)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app

# Node environment
NODE_ENV=development
