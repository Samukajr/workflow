# Database
DATABASE_URL=postgresql://user:password@localhost:5432/workflow_pagamentos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=workflow_pagamentos
DB_USER=postgres
DB_PASSWORD=password

# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# JWT
JWT_SECRET=seu_jwt_secret_muito_seguro_aqui
JWT_EXPIRATION=24h

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Em produção, use um diretório em disco persistente (ex.: /var/data/uploads)
# UPLOAD_DIR=/var/data/uploads

# Email Configuration (para recuperação de senha)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app
APP_NAME=Sistema de Workflow
FRONTEND_URL=http://localhost:5173

# Gmail: Use "Senhas de app" (https://myaccount.google.com/apppasswords)
# Outlook: smtp.office365.com (porta 587)
# SendGrid/Mailgun: Configure conforme documentação

# SMS Configuration (Fase 3B)
SMS_ENABLED=false
SMS_PROVIDER=webhook
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
SMS_FALLBACK_PHONE=

# LGPD & Segurança
SESSION_TIMEOUT=3600
LOG_LEVEL=info
ENABLE_AUDIT_LOG=true
