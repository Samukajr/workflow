// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum StatusRequisicao {
  PENDENTE
  VALIDANDO
  VALIDADA
  PAGANDO
  PAGA
  REJEITADA
  CANCELADA
}

enum TipoDepartamento {
  SUBMISSAO
  VALIDACAO
  FINANCEIRO
  ADMIN
}

enum TipoDocumento {
  NOTA_FISCAL
  BOLETO
  COMPROVANTE_PAGAMENTO
  OUTRO
}

// ==========================================
// DEPARTAMENTOS
// ==========================================

model Departamento {
  id        String   @id @default(cuid())
  nome      String   @unique
  tipo      TipoDepartamento
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios    Usuario[]
  requisicoes Requisicao[]
  validacoes  Validacao[]
  pagamentos  Pagamento[]

  @@map("departamentos")
}

// ==========================================
// USUÁRIOS
// ==========================================

model Usuario {
  id              String   @id @default(cuid())
  nome            String
  email           String   @unique
  cpf             String?  @unique
  senha           String
  ativo           Boolean  @default(true)
  ultimoAcesso    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  departamentoId  String
  departamento    Departamento @relation(fields: [departamentoId], references: [id])

  requisicoes     Requisicao[]
  validacoes      Validacao[]
  pagamentos      Pagamento[]
  auditoria       LogAuditoria[]

  @@map("usuarios")
}

// ==========================================
// REQUISIÇÕES DE PAGAMENTO
// ==========================================

model Requisicao {
  id                String   @id @default(cuid())
  numero            String   @unique
  descricao         String
  valor             Float
  status            StatusRequisicao @default(PENDENTE)
  dataVencimento    DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  usuarioId         String
  usuario           Usuario @relation(fields: [usuarioId], references: [id])

  departamentoId    String
  departamento      Departamento @relation(fields: [departamentoId], references: [id])

  documentos        Documento[]
  validacoes        Validacao[]
  pagamentos        Pagamento[]

  @@map("requisicoes")
}

// ==========================================
// DOCUMENTOS (NF, BOLETOS)
// ==========================================

model Documento {
  id              String   @id @default(cuid())
  nome            String
  tipo            TipoDocumento
  caminho         String   // URL ou caminho do arquivo
  tamanho         Int      // em bytes
  checksum        String?  // para integridade
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requisicaoId    String
  requisicao      Requisicao @relation(fields: [requisicaoId], references: [id], onDelete: Cascade)

  @@map("documentos")
}

// ==========================================
// VALIDAÇÕES
// ==========================================

model Validacao {
  id              String   @id @default(cuid())
  status          String   // APROVADO, REJEITADO, PENDENTE
  motivo          String?
  comentario      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requisicaoId    String
  requisicao      Requisicao @relation(fields: [requisicaoId], references: [id], onDelete: Cascade)

  usuarioId       String
  usuario         Usuario @relation(fields: [usuarioId], references: [id])

  departamentoId  String
  departamento    Departamento @relation(fields: [departamentoId], references: [id])

  @@map("validacoes")
}

// ==========================================
// PAGAMENTOS
// ==========================================

model Pagamento {
  id              String   @id @default(cuid())
  numero          String   @unique
  valor           Float
  dataPagamento   DateTime?
  dataComprovante DateTime?
  comprovante     String?  // URL do comprovante
  status          String   // PENDENTE, PROCESSANDO, PAGO, ERRO
  motivo          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requisicaoId    String
  requisicao      Requisicao @relation(fields: [requisicaoId], references: [id], onDelete: Cascade)

  usuarioId       String
  usuario         Usuario @relation(fields: [usuarioId], references: [id])

  departamentoId  String
  departamento    Departamento @relation(fields: [departamentoId], references: [id])

  @@map("pagamentos")
}

// ==========================================
// AUDITORIA (LGPD)
// ==========================================

model LogAuditoria {
  id              String   @id @default(cuid())
  acao            String   // CREATE, READ, UPDATE, DELETE
  entidade        String   // Nome da tabela
  entidadeId      String   // ID do registro
  alteracoes      String?  // JSON com antes/depois
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  usuarioId       String
  usuario         Usuario @relation(fields: [usuarioId], references: [id])

  @@map("logs_auditoria")
}

// ==========================================
// CONFIGURAÇÕES
// ==========================================

model Configuracao {
  id              String   @id @default(cuid())
  chave           String   @unique
  valor           String
  tipo            String   // string, number, boolean, json
  descricao       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("configuracoes")
}
