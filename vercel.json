{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://workflow-3gbs.onrender.com"
  },
  "redirects": [
    {
      "source": "/api/:path*",
      "destination": "https://workflow-3gbs.onrender.com/api/:path*"
    }
  ]
}
